{
  "permissions": {
    "allow": [
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm typecheck:household-app:*)",
      "Bash(pnpm tsc:*)",
      "Bash(npx tsc:*)",
      "Bash(touch **/*.{ts,tsx,jsx,js,json,sh,md})",
      "WriteFile(**/*.ts)",
      "WriteFile(**/*.tsx)",
      "WriteFile(**/*.jsx)",
      "WriteFile(**/*.js)",
      "WriteFile(**/*.json)",
      "WriteFile(**/*.jsonc)",
      "WriteFile(**/*.sh)",
      "WriteFile(**/*.md)",
      "mcp__ide__getDiagnostics",
      "Bash(pnpm --filter household-app typecheck:*)",
      "Bash(cat:*)",
      "Bash(mkdir:*)",
      "Bash(gh pr list:*)",
      "Bash(gh api:*)",
      "Bash(git show:*)",
      "Bash(pnpm --filter household-app exec tsc --noEmit)",
      "Bash(pnpm exec tsc:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm -r build:*)",
      "Bash(pnpm --filter delete-expired-session-cron exec tsc:*)",
      "Bash(pnpm install)",
      "Bash(tree:*)",
      "Bash(find:*)",
      "WebSearch",
      "Bash(grep:*)",
      "Bash(git log:*)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/mnt/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe -Command \"Add-Type -AssemblyName System.Windows.Forms; [System.Console]::Beep(800, 700); [System.Windows.Forms.MessageBox]::Show('Claude Codeが確認を求めています')\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/mnt/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe -Command \"Add-Type -AssemblyName System.Windows.Forms; [System.Console]::Beep(500, 1000); [System.Windows.Forms.MessageBox]::Show('Claude Codeが作業を完了しました。')\""
          }
        ]
      }
    ]
  }
}